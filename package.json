{
  "name": "uguisu",
  "version": "2.0.0",
  "description§": "AWS CDK construct to monitor security related event of CloudTrail logs based on AWS CIS benchmark",
  "repository": {
    "type": "git",
    "url": "https://github.com/cookpad/uguisu.git"
  },
  "homepage": "https://github.com/cookpad/uguisu",
  "scripts": {
    "prepare": "tsc",
    "postinstall": "node -e \"const fs=require('fs'); ['@aws-cdk/core/node_modules/minimatch','@aws-cdk/cx-api/node_modules/semver','@aws-cdk/cloud-assembly-schema/node_modules/semver'].forEach(p=>{const full='node_modules/'+p; try{fs.rmSync(full,{recursive:true,force:true}); console.log('Removed nested vulnerable package:',p)}catch(e){}})\"",
    "build": "tsc",
    "watch": "tsc -w",
    "test": "tsc; jest",
    "cdk": "cdk"
  },
  "main": "./lib/uguisu-stack.js",
  "type": "./lib/uguisu-stack.d.ts",
  "files": [
    "lib"
  ],
  "license": "MIT",
  "devDependencies": {
    "@aws-cdk/assert": "1.204.0",
    "@types/jest": "^26.0.0",
    "@types/node": "^16.18.0",
    "jest": "^26.6.3",
    "ts-jest": "^26.5.6",
    "aws-cdk": "2.1108.0",
    "ts-node": "^8.1.0",
    "typescript": "~4.9.5"
  },
  "dependencies": {
    "@aws-cdk/aws-iam": "1.204.0",
    "@aws-cdk/aws-lambda-event-sources": "1.204.0",
    "@aws-cdk/aws-lambda-nodejs": "1.204.0",
    "@aws-cdk/aws-sns": "1.204.0",
    "@aws-cdk/aws-sns-subscriptions": "1.204.0",
    "@aws-cdk/aws-sqs": "1.204.0",
    "@aws-cdk/core": "1.204.0",
    "@types/aws-lambda": "^8.10.57",
    "aws-sdk": "^2.1693.0",
    "source-map-support": "^0.5.16"
  },
  "overrides": {
    "minimatch": "3.1.5",
    "semver": "7.7.4",
    "braces": "3.0.3",
    "micromatch": "4.0.8"
  },
  "cdk-lambda": "/asset-output/index.js",
  "targets": {
    "cdk-lambda": {
      "context": "node",
      "includeNodeModules": {
        "aws-sdk": false
      },
      "sourceMap": false,
      "minify": false,
      "engines": {
        "node": ">= 12"
      }
    }
  }
}