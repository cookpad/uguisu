{
  "name": "uguisu",
  "version": "2.0.0",
  "description": "AWS CDK construct to monitor security related event of CloudTrail logs based on AWS CIS benchmark",
  "repository": {
    "type": "git",
    "url": "https://github.com/cookpad/uguisu.git"
  },
  "homepage": "https://github.com/cookpad/uguisu",
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint . --max-warnings=0",
    "test": "tsc; jest",
    "cdk": "cdk"
  },
  "main": "./lib/uguisu-stack.js",
  "types": "./lib/uguisu-stack.d.ts",
  "files": [
    "lib"
  ],
  "license": "MIT",
  "peerDependencies": {
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^16.18.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "aws-cdk": "2.1108.0",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1",
    "eslint": "^10.0.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^8.1.0",
    "typescript": "~5.5.4"
  },
  "dependencies": {
    "@types/aws-lambda": "^8.10.57",
    "source-map-support": "^0.5.16"
  },
  "overrides": {
    "minimatch": "3.1.5",
    "semver": "7.7.4",
    "braces": "3.0.3",
    "micromatch": "4.0.8"
  },
  "cdk-lambda": "/asset-output/index.js",
  "targets": {
    "cdk-lambda": {
      "context": "node",
      "sourceMap": false,
      "minify": false,
      "engines": {
        "node": ">= 12"
      }
    }
  }
}
